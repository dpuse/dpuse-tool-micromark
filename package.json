{
    "name": "@dpuse/dpuse-tool-micromark",
    "version": "0.1.994",
    "description": "A library that wraps the Micromark markdown parser and Speed Highlight code highlighter.",
    "license": "MIT",
    "private": false,
    "type": "module",
    "homepage": "https://www.dpuse.app",
    "repository": {
        "type": "git",
        "url": "https://github.com/dpuse/dpuse-tool-micromark.git"
    },
    "bugs": {
        "url": "https://github.com/dpuse/dpuse-tool-micromark/issues"
    },
    "module": "./dist/dpuse-tool-micromark.es.js",
    "types": "./dist/types/src/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/dpuse-tool-micromark.es.js",
            "types": "./dist/types/src/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "prettier": "@dpuse/dpuse-development/prettierrc",
    "dependencies": {
        "@speed-highlight/core": "^1.2.15",
        "micromark": "^4.0.2",
        "micromark-extension-gfm-table": "^2.1.1"
    },
    "devDependencies": {
        "@dpuse/dpuse-development": "^0.3.486",
        "@dpuse/eslint-config-dpuse": "^1.0.55",
        "@types/node": "^25.5.0",
        "@typescript-eslint/eslint-plugin": "^8.57.2",
        "@typescript-eslint/parser": "^8.57.2",
        "eslint": "^9.39.4",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-security": "^4.0.0",
        "eslint-plugin-sonarjs": "^4.0.2",
        "eslint-plugin-unicorn": "^63.0.0",
        "jiti": "^2.6.1",
        "license-downloader": "^1.3.3",
        "license-report": "^6.8.2",
        "license-report-check": "^0.1.2",
        "license-report-recursive": "^6.8.3",
        "npm-check-updates": "^19.6.5",
        "owasp-dependency-check": "^1.0.1",
        "prettier": "^3.8.1",
        "rollup-plugin-visualizer": "^7.0.1",
        "typescript": "^5.9.3",
        "vite": "^8.0.2",
        "vite-plugin-dts": "^4.5.4"
    },
    "scripts": {
        "audit": "node -e \"import('@dpuse/dpuse-development').then(m => m.auditDependencies())\"",
        "build": "node -e \"import('@dpuse/dpuse-development').then(m => m.buildProject())\"",
        "check": "node -e \"import('@dpuse/dpuse-development').then(m => m.checkDependencies())\"",
        "document": "node -e \"import('@dpuse/dpuse-development').then(m => m.documentDependencies(['CC0-1.0','MIT']))\"",
        "format": "node -e \"import('@dpuse/dpuse-development').then(m => m.formatCode())\"",
        "lint": "node -e \"import('@dpuse/dpuse-development').then(m => m.lintCode())\"",
        "release": "node -e \"import('@dpuse/dpuse-development').then(m => m.releaseProject())\"",
        "sync": "node -e \"import('@dpuse/dpuse-development').then(m => m.syncProjectWithGitHub())\"",
        "test": "node -e \"import('@dpuse/dpuse-development').then(m => m.testProject())\"",
        "update": "node -e \"import('@dpuse/dpuse-development').then(m => m.updateDPUseDependencies(['development']))\""
    }
}